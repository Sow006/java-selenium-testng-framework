<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="UI Automation Regression Suite" verbose="2" parallel="methods" thread-count="2">

    <listeners>
        <listener class-name="com.saisowmya.automation.listeners.RetryListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="com.saisowmya.automation.tests.LoginTest"/>
        </classes>
    </test>

    <test name="E2E Checkout Tests">
        <classes>
            <class name="com.saisowmya.automation.tests.CheckoutE2ETest"/>
        </classes>
    </test>

</suite>
